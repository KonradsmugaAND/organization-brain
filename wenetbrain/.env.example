# OrgBrain — Local PoC Environment Configuration

# ── Google Cloud (optional — required for Gemini API) ──────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=True

# ── Qdrant (local vector database) ─────────────────────────────────────
QDRANT_URL=http://localhost:6333
EMBEDDING_SIZE=768

# ── SQLite (local relational DB) ───────────────────────────────────────
WENETBRAIN_DB_PATH=wenetbrain.db

# ── ClickUp (optional — required for task export) ──────────────────────
CLICKUP_API_KEY=pk_your_clickup_api_key
CLICKUP_DEFAULT_LIST_ID=your_list_id

# ── Microsoft 365 (optional — required for calendar sync) ──────────────
MS365_CLIENT_ID=your_azure_app_client_id
MS365_CLIENT_SECRET=your_azure_app_client_secret
MS365_TENANT_ID=your_tenant_id
MS365_ACCESS_TOKEN=  # populated after OAuth flow

# ── Ollama (local LLM fallback) ────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
